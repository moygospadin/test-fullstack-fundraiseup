{
  "name": "fullstack-test-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "bundle:tracker": "esbuild src/Tracker/tracker.ts --bundle --platform=browser --format=iife --minify --outfile=dist/Tracker/tracker.js && terser dist/Tracker/tracker.js -c -m -o dist/Tracker/tracker.js",
    "build:server": "tsc -p tsconfig.json && npm run bundle:tracker",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "esbuild": "^0.23.1",
    "prettier": "^3.3.3",
    "terser": "^5.31.6",
    "typescript": "^5.6.3"
  }
}
